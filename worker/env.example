# Copy values into Cloudflare secrets/variables; do not commit real credentials.

# Required for admin content and media management
ADMIN_PASSWORD=replace-with-a-long-random-password

# Configure at least one AI provider
GEMINI_KEY_1=
CEREBRAS_KEY_1=
GROK_API_KEY=

# Recommended production settings
CORS_ORIGIN=https://YOUR-USERNAME.github.io
DEBUG_ERRORS=false
STRICT_ACCURACY_GATE=true
RATE_LIMIT_PER_MINUTE=90
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_PER_MINUTE=20
ADMIN_RATE_LIMIT_WINDOW_SECONDS=300

# Optional provider model overrides
GEMINI_MODEL=
CEREBRAS_MODEL=
GROK_MODEL=
